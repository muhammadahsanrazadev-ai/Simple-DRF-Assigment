# =============================================================================
# ENVIRONMENT VARIABLES — EXAMPLE / TEMPLATE
# =============================================================================
# Copy this file to ".env" and fill in real values:
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows)
#
# ".env" itself is git-ignored and must never be committed — this example
# file is what gets committed/shared instead, so it contains no real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# DJANGO CORE SETTINGS
# -----------------------------------------------------------------------------
SECRET_KEY=replace-with-a-real-generated-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost


# -----------------------------------------------------------------------------
# JWT (SIMPLEJWT) — ACCESS & REFRESH TOKEN LIFETIMES (in minutes)
# -----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_MINUTES=10080


# -----------------------------------------------------------------------------
# CELERY / REDIS (MESSAGE BROKER)
# -----------------------------------------------------------------------------
# Start Redis locally via Docker before running Celery:
#   docker run -d --name redis-server -p 6379:6379 redis:alpine
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Set True only for quick local testing without Redis running (tasks then
# run inline/synchronously). Keep False for real Celery behaviour.
CELERY_TASK_ALWAYS_EAGER=False


# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# -----------------------------------------------------------------------------
# console backend = emails print to terminal (safe default for local dev)
# smtp backend    = emails actually sent via the host/credentials below
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=noreply@taskmanager.local
